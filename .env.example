# ============================================
# Copa Agent — Environment Configuration
# ============================================

# Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
AGENT_BUILDER_AGENT_ID=your-agent-builder-agent-id

# Agent model (used by Gemini API and Vertex AI backends)
COPA_MODEL=gemini-2.5-flash

# Vertex AI Search grounding (optional — local runbook search used if unset)
VERTEX_SEARCH_DATASTORE_ID=
VERTEX_SEARCH_LOCATION=global

# GitLab Configuration
GITLAB_PERSONAL_ACCESS_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GITLAB_API_URL=https://gitlab.com/api/v4
GITLAB_GROUP_PATH=your-gitlab-group

# Firestore (uses default GCP credentials if deployed on Cloud Run)
FIRESTORE_COLLECTION=copa_agent_sessions

# Server
PORT=8080
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Optional: Gemini API Key (for local dev without Agent Builder)
GOOGLE_API_KEY=your-gemini-api-key
